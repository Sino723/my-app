<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Nautilus - Genres</title>
  <style>
    body { font-family: 'Times New Roman', Times, serif; padding: 20px; background-color: #000538; color: #ffffff; }
    h1.main-title { text-align: center; font-size: 3.5em; font-weight: normal; letter-spacing: 5px; margin-top: 20px; margin-bottom: 40px; color: #ffffff; }
    h2 { color: #ffffff; border-bottom: 1px solid #4a6fa5; padding-bottom: 5px; font-weight: normal; }
    
    .genre-group { background: #23396d; border: 1px solid #4a6fa5; border-radius: 8px; padding: 20px; margin-bottom: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.3); }
    .genre-title { display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #4a6fa5; padding-bottom: 10px; margin-bottom: 15px; }
    
    .task-list { list-style: none; padding-left: 0; }
    .task-item { padding: 10px 8px; border-bottom: 1px dashed #4a6fa5; display: flex; align-items: center; }
    .task-item:last-child { border-bottom: none; }
    .task-meta { font-size: 0.85em; color: #aaaaaa; margin-left: 10px; }
    
    .btn-secondary { padding: 8px 15px; background: #23396d; color: #ffffff; border: 1px solid #ffffff; border-radius: 4px; cursor: pointer; font-family: 'Times New Roman', Times, serif; transition: 0.2s; text-decoration: none; display: inline-block; }
    .btn-secondary:hover { background: #ffffff; color: #000538; }
    
    .action-btn { background: none; border: none; font-size: 0.9em; cursor: pointer; transition: 0.2s; color: #aaaaaa; font-family: 'Times New Roman', Times, serif; text-decoration: underline; padding: 0 5px;}
    .action-btn:hover { color: #ffffff; }
  </style>
</head>
<body>
  <h1 class="main-title">Nautilus</h1>
  
  <div style="margin-bottom: 20px;">
    <a href="/" class="btn-secondary">< Back to Top</a>
  </div>

  <h2>Tasks by Genre</h2>

  <% if (genres.length === 0) { %>
    <p style="color: #aaaaaa;">No genres registered.</p>
  <% } else { %>
    <% genres.forEach(genre => { %>
      <div class="genre-group">
        <div class="genre-title">
          <h2 style="margin: 0; border: none;"><%= genre.title %></h2>
          <form action="/tasks/<%= genre.id %>/delete" method="POST" style="margin: 0;" onsubmit="return confirm('Are you sure you want to delete this genre?\n(Tasks in this genre will remain without a genre.)');">
            <button type="submit" class="action-btn">Delete</button>
          </form>
        </div>
        
        <ul class="task-list">
          <% const tasksInGenre = tasksWithGenre.filter(t => t.from_template_id === genre.id); %>
          <% if (tasksInGenre.length === 0) { %>
            <li style="color: #aaaaaa; padding: 8px;">No tasks in this genre.</li>
          <% } else { %>
            <% tasksInGenre.forEach(task => { %>
              <li class="task-item">
                <span style="<%= task.is_completed ? 'text-decoration: line-through; opacity: 0.5;' : '' %>;">
                  <%= task.title %>
                </span>
                <span class="task-meta" style="<%= task.is_completed ? 'opacity: 0.5;' : '' %>">
                  (Weight: <%= task.weight %> 
                  <% if (task.deadline) { %> | Deadline: <%= new Date(task.deadline).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute:'2-digit' }) %><% } %>)
                </span>
              </li>
            <% }) %>
          <% } %>
        </ul>
      </div>
    <% }) %>
  <% } %>
</body>
</html>