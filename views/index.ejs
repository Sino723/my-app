<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>タスク管理アプリ</title>
</head>
<body>
  <h1>タスク管理アプリ（爆速MVP版）</h1>

  <!-- タスク登録フォーム -->
  <form action="/tasks" method="POST">
    <input type="text" name="title" placeholder="新しいタスクを入力" required>
    <button type="submit">タスクを追加</button>
  </form>

  <hr>

  <!-- タスク一覧表示 -->
  <h2>今日のタスク</h2>
  <ul>
    <% if (tasks.length === 0) { %>
      <li>タスクはまだありません。</li>
    <% } else { %>
      <% tasks.forEach(task => { %>
        <li><%= task.title %></li>
      <% }) %>
    <% } %>
  </ul>
</body>
</html>